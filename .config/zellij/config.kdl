// theme
//----------------------------------------------------------------------------
themes {
    my-theme {
        text_unselected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        text_selected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        ribbon_selected {
            base 228 233 232
            background 164 140 50
            emphasis_0 228 233 232
            emphasis_1 7 102 120
            emphasis_2 137 106 152
            emphasis_3 0 142 196
        }
        ribbon_unselected {
            base 228 233 232
            background 101 115 126
            emphasis_0 228 233 232
            emphasis_1 66 66 66
            emphasis_2 0 142 196
            emphasis_3 137 106 152
        }
        table_title {
            base 164 140 50
            background 0
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        table_cell_selected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        table_cell_unselected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        list_selected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        list_unselected {
            base 66 66 66
            background 228 233 232
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 164 140 50
            emphasis_3 137 106 152
        }
        frame_selected {
            base 164 140 50
            background 0
            emphasis_0 7 102 120
            emphasis_1 32 165 186
            emphasis_2 137 106 152
            emphasis_3 0
        }
        frame_highlight {
            base 7 102 120
            background 0
            emphasis_0 137 106 152
            emphasis_1 0
            emphasis_2 7 102 120
            emphasis_3 7 102 120
        }
        exit_code_success {
            base 164 140 50
            background 0
            emphasis_0 32 165 186
            emphasis_1 228 233 232
            emphasis_2 137 106 152
            emphasis_3 0 142 196
        }
        exit_code_error {
            base 228 233 232
            background 0
            emphasis_0 168 156 20
            emphasis_1 0
            emphasis_2 0
            emphasis_3 0
        }
        multiplayer_user_colors {
            player_1 137 106 152
            player_2 0 142 196
            player_3 0
            player_4 168 156 20
            player_5 32 165 186
            player_6 0
            player_7 228 233 232
            player_8 0
            player_9 0
            player_10 0
        }
    }
}

theme "my-theme"

