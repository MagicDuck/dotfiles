// general options
//----------------------------------------------------------------------------

layout_dir "/Users/Stephan.Badragan/.config/zellij/layouts"
default_layout "compact"
pane_frames false
scroll_buffer_size 10000
scrollback_editor "/opt/homebrew/bin/nvim -u /Users/Stephan.Badragan/.config/nvim/init_as_pager.lua"
session_serialization true
serialize_pane_viewport false
show_startup_tips false
mouse_click_through true
mouse_mode true

// plugins
//----------------------------------------------------------------------------

// keybinds
//----------------------------------------------------------------------------

keybinds clear-defaults=true {
    normal {
        bind "Super c" { Copy; }
        bind "Super h" { GoToPreviousTab; }
        bind "Super l" { GoToNextTab; }
        bind "Super Shift l" { MoveTab "Left"; }
        bind "Super Shift h" { MoveTab "Right"; }
        bind "Super t" { NewTab; SwitchToMode "renametab"; TabNameInput 0;}
        bind "Super n" { SwitchToMode "renametab"; TabNameInput 0;}
        bind "Super x" { CloseTab; }
        bind "Super d" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "normal"
        }
        bind "Super r" {
            LaunchOrFocusPlugin "zellij:layout-manager" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal"
        }
        bind "Super Shift x" { Quit; }
        bind "Super i" { EditScrollback; SwitchToMode "normal"; }
        bind "Super u" { SwitchToMode "scroll"; }
        bind "Super k" {
            Run "lazygit" {
                floating true
                close_on_exit true
            };
            Resize "Increase";
            SwitchToMode "Normal";
        }
    }

    scroll {
        bind "/" { SwitchToMode "entersearch"; SearchInput 0; }
    }

    shared_among "scroll" "search" {
        bind "Ctrl c" { ScrollToBottom; SwitchToMode "normal"; }
        bind "PageDown" { PageScrollDown; }
        bind "PageUp" { PageScrollUp; }
        bind "up" { ScrollUp; }
        bind "down" { ScrollDown; }
        bind "j" { ScrollDown; }
        bind "k" { ScrollUp; }
    }
    search {
        bind "n" { Search "down"; }
        bind "N" { Search "up"; }
        bind "esc" { ScrollToBottom; SwitchToMode "normal"; }
    }

    shared_except "normal" "locked" "entersearch" {
        bind "enter" { SwitchToMode "normal"; }
    }
    shared_except "normal" "locked" "entersearch" "search" "renametab" "renamepane" {
        bind "esc" { SwitchToMode "normal"; }
    }
    entersearch {
        bind "esc" { SwitchToMode "scroll"; }
        bind "enter" { SwitchToMode "search"; }
    }
    renametab {
        bind "esc" { UndoRenameTab; SwitchToMode "tab"; }
    }
    shared_among "renametab" "renamepane" {
        bind "Ctrl c" { SwitchToMode "normal"; }
    }
    renamepane {
        bind "esc" { UndoRenamePane; SwitchToMode "pane"; }
    }

